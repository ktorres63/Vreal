---
import { Globe, User, Menu } from "@lucide/astro";
---

<header class="absolute top-0 left-0 w-full z-50">
  <div
    class="mx-auto max-w-7xl px-6 md:px-12 py-4 flex items-center justify-between"
  >
    <!-- Logo (imagen real) -->
    <a href="/" class="flex items-center">
      <img
        src="/images/VrealLogo.png"
        alt="VRReal Logo"
        class="h-8 md:h-10 object-contain"
      />
    </a>

    <!-- Navigation (desktop) -->
    <nav class="hidden md:flex items-center gap-8 text-sm">
      <a href="#" class="text-blue-400 border-b-2 border-blue-400 pb-1">
        Destinations
      </a>
      <a href="#" class="text-gray-300 hover:text-white transition">
        Experiences
      </a>
      <a href="#" class="text-gray-300 hover:text-white transition">
        Technology
      </a>
      <a href="#" class="text-gray-300 hover:text-white transition"> About </a>
    </nav>

    <!-- Right side -->
    <div class="flex items-center gap-3 md:gap-4">
      <!-- Icons (desktop only) -->
      <div class="hidden md:flex items-center gap-3 text-gray-300">
        <Globe class="w-5 h-5 hover:text-white transition cursor-pointer" />
        <User class="w-5 h-5 hover:text-white transition cursor-pointer" />
      </div>

      <!-- Button (hidden en móvil para no saturar) -->
      <a
        href="#"
        class="hidden md:inline-flex px-5 py-2 rounded-lg bg-blue-500 hover:bg-blue-600 text-white text-sm font-medium transition shadow-md"
      >
        Get Started
      </a>

      <!-- Mobile menu button -->
      <button class="md:hidden text-gray-300 hover:text-white">
        <Menu class="w-6 h-6" />
      </button>
    </div>
  </div>

  <!-- Background gradient -->
  <div
    class="absolute inset-0 -z-10 bg-linear-to-b from-black/80 via-black/40 to-transparent"
  >
  </div>
</header>
