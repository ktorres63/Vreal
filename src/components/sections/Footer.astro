---
import { Mail, Phone } from "@lucide/astro";
---

<footer class="bg-[#0b0f2a] text-gray-300 pt-16 pb-10">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <!-- GRID -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Logo + Info -->
      <div>
        <img src="/images/VrealLogo.png" alt="VRReal Logo" class="h-10 mb-4" />

        <p class="text-sm leading-relaxed text-gray-400">
          Empresa inscrita en el registro https://www.sbs.gob.pe/<br />
          asdfghjk/sdfghjkl<br />
          RESOLUCION N° 092223123123132<br />
          RUC: 201022222113123
        </p>

        <!-- Social -->
        <div class="mt-6">
          <p class="text-sm mb-3">Síguenos en nuestras redes sociales</p>
          <div class="flex gap-4">
            <Phone class="w-5 h-5 hover:text-white cursor-pointer" />
            <Phone class="w-5 h-5 hover:text-white cursor-pointer" />
            <Phone class="w-5 h-5 hover:text-white cursor-pointer" />
          </div>
        </div>
      </div>

      <!-- Menu -->
      <div>
        <h3 class="text-white font-semibold mb-4">Menu</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="#" class="hover:text-white">Inicio</a></li>
          <li><a href="#" class="hover:text-white">¿Cómo funciona?</a></li>
          <li><a href="#" class="hover:text-white">Beneficios</a></li>
          <li>
            <a href="#" class="hover:text-white">Experiencias disponibles</a>
          </li>
          <li><a href="#" class="hover:text-white">Preguntas frecuentes</a></li>
        </ul>
      </div>

      <!-- Links -->
      <div>
        <h3 class="text-white font-semibold mb-4">Enlaces de interes</h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="#" class="hover:text-white">Política de privacidad</a>
          </li>
          <li>
            <a href="#" class="hover:text-white">Términos y condiciones</a>
          </li>
          <li>
            <a href="#" class="hover:text-white">Libro de reclamaciones</a>
          </li>
          <li><a href="#" class="hover:text-white">Política de cookies</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-white font-semibold mb-4">Contáctanos</h3>

        <div class="space-y-3 text-sm">
          <div class="flex items-center gap-2">
            <Mail class="w-4 h-4" />
            <span>servicioalcliente@vreal.pe</span>
          </div>

          <div class="flex items-center gap-2">
            <Phone class="w-4 h-4" />
            <span>989919239 (solo whatsapp)</span>
          </div>
        </div>

        <!-- CTA -->
        <a
          href="#"
          class="inline-block mt-6 px-6 py-3 bg-blue-500 hover:bg-blue-600 text-white rounded-lg font-medium transition"
        >
          Reserva un viaje
        </a>
      </div>
    </div>

    <!-- Divider -->
    <div
      class="border-t border-white/10 mt-12 pt-6 text-center text-sm text-gray-400"
    >
      <p>2026 © Vreal Peru</p>

      <p class="mt-4 max-w-3xl mx-auto text-xs leading-relaxed">
        Lorem ipsum dolor sit amet consectetur adipisicing elit, vestibulum
        commodo elementum vel penatibus eu...
      </p>
    </div>
  </div>
</footer>
